{
  "name": "@archguard/cli",
  "version": "0.1.0",
  "description": "Contract & Architecture Evolution Manager for NestJS — automated API diff and documentation.",
  "keywords": [
    "nestjs",
    "openapi",
    "swagger",
    "cli",
    "api-diff",
    "architecture",
    "documentation"
  ],
  "author": "ArchGuard Contributors",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "archguard": "dist/bin/archguard.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "node -e \"require('fs').chmodSync('dist/bin/archguard.js', '755')\"",
    "prepare": "npm run build",
    "dev": "ts-node src/bin/archguard.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm test && npm run build"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "fast-json-patch": "^3.1.1",
    "js-yaml": "^4.1.0",
    "json-diff": "^1.0.6",
    "ora": "^5.4.1",
    "simple-git": "^3.21.0",
    "table": "^6.8.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/json-diff": "^1.0.3",
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/core/**/*.ts",
      "src/utils/**/*.ts",
      "!src/**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  }
}
